# Airtable — server-side only (no NEXT_PUBLIC_ prefix)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Formspree — must use NEXT_PUBLIC_ prefix because @formspree/react runs client-side
# Note: the brief calls this FORMSPREE_ENDPOINT, but Next.js requires NEXT_PUBLIC_
# to expose any variable to the browser. Set this name in Vercel.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=
